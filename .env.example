DB_ROOT_PASSWORD=changeme-root
DB_NAME=suitecrm
DB_USER=suitecrm
DB_PASSWORD=changeme-db

SUITECRM_ADMIN_USER=admin
SUITECRM_ADMIN_PASSWORD=changeme-admin

SITE_URL=http://caddy
DEMO_DATA=no

# Uncomment both to serve over HTTPS via Caddy's automatic Let's Encrypt certs.
# Requires DOMAIN to resolve to this host with port 80 reachable from the internet.
# DOMAIN=crm.example.org
# ACME_EMAIL=admin@example.org

# Encrypts the restic backup repository at data/backups. restic encrypts client-side,
# so losing this password makes existing backups permanently unrecoverable — store it
# somewhere durable (password manager), separate from this host.
RESTIC_PASSWORD=changeme-restic-password
